# ── RAMA AI OS — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyDWpfmo1SeDFQZbxSfGFOity3Y4VTWk3-A

# ── Ollama local LLM ──────────────────────────────────────────────────────
# Download Ollama: https://ollama.com/
# Then pull models:
#   ollama pull llama3
#   ollama pull phi3
#   ollama pull qwen2.5-coder
#   ollama pull llava
OLLAMA_URL=http://localhost:11434
OLLAMA_GPU_ACCELERATION=cuda        # cuda | metal | cpu
OLLAMA_NUM_GPUS=1
OLLAMA_MEMORY_STRATEGY=DYNAMIC      # DYNAMIC | STATIC

# ── Security ──────────────────────────────────────────────────────────────
NETWORK_SENTINEL_ENABLED=true

# ── Neo4j Knowledge Graph ─────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_PASSWORD=rama_secret

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google Search (optional, for OSINT) ───────────────────────────────────
# GOOGLE_SEARCH_API_KEY=your_key_here
# GOOGLE_SEARCH_CX=your_cx_here

# ── Firebase (optional, for cloud memory) ────────────────────────────────
# FIREBASE_PROJECT_ID=your_project
# FIREBASE_PRIVATE_KEY=your_key
# FIREBASE_CLIENT_EMAIL=your_email
